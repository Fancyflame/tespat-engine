{
  "patterns": {
    "OpenDoor": {
      "width": 4,
      "capture": [
        "Room",
        "Wall",
        "Empty",
        "Anchor"
      ],
      "replace": [
        "RoomWithDoor",
        "Anchor",
        "Empty",
        "Anchor"
      ]
    },
    "SetRoomHasDoor": {
      "width": 2,
      "capture": [
        "Room",
        "RoomWithDoor"
      ],
      "replace": [
        "RoomWithDoor",
        "RoomWithDoor"
      ]
    },
    "CreatePath": {
      "width": 3,
      "capture": [
        "PathHead",
        "Empty",
        "Anchor"
      ],
      "replace": [
        "PathBacktrace",
        "PathBacktrace",
        "PathHead"
      ]
    },
    "BackwardPath": {
      "width": 3,
      "capture": [
        "PathBacktrace",
        "PathBacktrace",
        "PathHead"
      ],
      "replace": [
        "PathHead",
        "Path",
        "Path"
      ]
    },
    "CreateConnectivePath": {
      "width": 3,
      "capture": [
        "Anchor",
        "Path",
        "Path"
      ],
      "replace": [
        "Anchor",
        "Path",
        "Anchor"
      ]
    },
    "DripDoor": {
      "width": 3,
      "capture": [
        "Anchor",
        "Empty",
        "Path"
      ],
      "replace": [
        "Anchor",
        "Path",
        "Anchor"
      ]
    },
    "DestroyWall": {
      "width": 3,
      "capture": [
        "*",
        "Empty",
        "*",
        "Path",
        "Empty",
        "Path",
        "*",
        "Empty",
        "*"
      ],
      "replace": [
        "*",
        "Empty",
        "*",
        "Path",
        "Path",
        "Path",
        "*",
        "Empty",
        "*"
      ]
    },
    "ClearDeadEnd": {
      "width": 3,
      "capture": [
        "Empty",
        "Empty",
        "Empty",
        "Empty",
        "Path",
        "Empty"
      ],
      "replace": [
        "Empty",
        "Empty",
        "Empty",
        "Empty",
        "Empty",
        "Empty"
      ]
    }
  },
  "patternOrder": [
    "OpenDoor",
    "SetRoomHasDoor",
    "CreatePath",
    "BackwardPath",
    "CreateConnectivePath",
    "DripDoor",
    "DestroyWall",
    "ClearDeadEnd"
  ],
  "colors": {
    "Wall": "#f07000",
    "Room": "#0a6cff",
    "Empty": "#423333",
    "RoomVertex": "#ffc300",
    "RoomWithDoor": "#05e6ff",
    "PathHead": "#ff0303",
    "*": "#000000",
    "Anchor": "#94009c",
    "PathBacktrace": "#5cff57",
    "Path": "#ffffff"
  }
}